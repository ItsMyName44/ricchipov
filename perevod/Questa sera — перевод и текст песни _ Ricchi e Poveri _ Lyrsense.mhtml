}

ol li { color: rgb(54, 54, 54); line-height: 1.4em; padding: 0px 0px 5px !i=
mportant; }

div#load { height: 16px; float: right; background: rgb(170, 19, 19); color:=
 white; position: relative; top: 14px; right: 3px; font-size: 0.7em; paddin=
g: 2px 10px; font-weight: bold; display: none; }

div.hr { height: 1px; }

div.hr1 { height: 1px; width: 50%; float: left; background: rgb(230, 228, 2=
28); }

