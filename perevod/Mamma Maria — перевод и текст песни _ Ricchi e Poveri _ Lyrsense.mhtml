@charset "utf-8";

@font-face { font-family: Montserrat; src: url("/font/montserrat-light.woff=
2") format("woff2"), url("/font/montserrat-light.woff") format("woff"); fon=
t-weight: 300; font-style: normal; font-display: swap; }

div.selectType { float: right; margin: 0px 0px 7px; }

body { outline: none; background: rgb(230, 228, 228); font-family: Geneva, =
sans-serif; font-size: 13px; margin: 0px; }

div.bodyLayout { max-width: 1220px; min-width: 970px; margin: 0px auto; }

a { color: rgb(35, 72, 140); transition-property: color; transition-duratio=
n: 0.5s; }

a:hover { color: red; }

a.dashed { text-decoration: none; border-bottom: 1px dashed rgb(35, 72, 140=
); }

a.redLink { color: red; }

a.smaller { text-decoration: none; }

.dashedRed:hover, a.redLink:hover { color: red !important; }

.dashedRed { color: rgb(255, 0, 0); text-decoration: none; border-bottom: 1=
px dashed rgb(255, 0, 0); font-weight: normal !important; }

div.dopBlock { background: white; border: 3px solid rgb(230, 228, 228); pad=
ding: 10px 15px; }

sup.dashedSup { border-bottom: 1px dotted rgb(35, 72, 140); color: rgb(35, =
72, 140); cursor: pointer; }

h2 sup { font-size: 12px; font-weight: bold; }

sup { vertical-align: baseline; position: relative; top: -4px; margin: 0px =
2px; font-size: 0.9em; }

input[type=3D"checkbox"] { position: relative; top: 2px; }

a.dashed:hover { border-bottom: none; }

a img { border: none; }

.pseudoLink { cursor: pointer; }

.linkToWiki { padding: 3px 0px 3px 20px; background: url("/images/wikipedia=
.png") left center no-repeat; }

.linkToLastfm { padding: 3px 0px 3px 20px; background: url("/images/lastfm.=
png") left center no-repeat; }

p { color: rgb(54, 54, 54); margin: 5px 0px 10px; line-height: 21px; }

table { border-collapse: collapse; }

td { padding: 0px; vertical-align: top; }

td.middleRow { }

.fullWidth { width: 100%; }

.hidden { display: none; }

.textToRight { text-align: right; }

h1 { color: rgb(78, 78, 78); margin: 0px; padding: 10px 0px 20px; font-size=
: 25px; font-family: Montserrat, sans-serif; font-weight: normal; }

h2 { color: rgb(78, 78, 78); margin: 0px; padding: 10px 10px 10px 0px; font=
