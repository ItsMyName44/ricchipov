@charset "utf-8";

* { box-sizing: border-box; }

body { margin: 0px; padding: 0px; font-family: Arial, sans-serif; line-heig=
ht: 1.55; color: rgb(97, 97, 97); background: rgb(245, 245, 245); }

h1 { font-size: 28px; margin-bottom: 7px; line-height: 1; }

a { color: rgb(75, 83, 177); text-decoration: none; }

a:active, a:focus, a:visited { color: rgb(75, 83, 177); }

a:hover { color: rgb(45, 49, 105); }

.dashed-link { border-bottom: 1px dashed rgb(75, 83, 177); }

.clear-both { clear: both; }

.float-right { float: right; }

.float-left { float: left; }

.text-muted { color: rgb(153, 153, 153); }

.text-center { text-align: center; }

.overflow-auto { overflow: auto; }

.font-size-20 { font-size: 20px; }

.vert-margin { margin-top: 20px; margin-bottom: 30px; }

.container { min-width: 320px; padding: 0px 10px; zoom: 1; }

.container::after, .container::before { content: ""; display: table; }

.container::after { clear: both; }

@media (min-width: 768px) {
  .container { padding: 0px 20px; }
}

@media (min-width: 1000px) {
  .container { max-width: 1000px; margin: 0px auto; }
}

@media (min-width: 1280px) {
  .container { max-width: 1280px; padding: 0px 30px; }
}

.container-fluid { padding: 0px 10px; min-width: 320px; zoom: 1; }

.container-fluid::after, .container-fluid::before { content: ""; display: t=
able; }

.container-fluid::after { clear: both; }

@media (min-width: 768px) {
  .container-fluid { padding: 0px 20px; }
}

@media (min-width: 1280px) {
  .container-fluid { padding: 0px 30px; }
}

.row { margin: 0px -15px; display: flex; flex-wrap: wrap; }

[class^=3D"col-"] { padding: 0px 10px; width: 100%; }

@media (min-width: 1280px) {
  [class^=3D"col-"] { padding: 0px 15px; }
}

.col-xxs-25 { width: 25%; }

.col-xxs-33 { width: 33.3333%; }

.col-xxs-50 { flex-basis: 50%; width: 50%; }

.col-xxs-66 { width: 66.6666%; }

.col-xxs-75 { width: 75%; }

.col-xxs-100 { width: 100%; }

