#nav-button { display: inline-block; vertical-align: top; margin-left: 14px=
; width: 30px; height: 40px; position: relative; border: none; background: =
0px 0px; outline: 0px; cursor: pointer; }

#nav-button span { display: block; height: 4px; background: rgb(95, 182, 64=
); position: absolute; left: 0px; right: 0px; transition: 0.3s; }

#nav-button span:nth-child(1) { top: 10px; }

#nav-button span:nth-child(2) { top: 18px; transition: 0.1s; }

