.header { top: 0px; left: 0px; right: 0px; background: rgb(255, 255, 255); =
box-shadow: rgba(202, 202, 202, 0.36) 0px 2px 5px 0px; }

.header__logo { display: block; float: left; font-family: "PT Sans", sans-s=
erif; font-size: 20px; line-height: 40px; font-weight: 700; color: rgb(187,=
 187, 187); text-decoration: none; margin-right: 10px; margin-top: 10px; }

.header__to-right { margin-top: 8px; float: right; }

.header .search-form { margin-top: 8px; display: none; }

@media (min-width: 480px) {
  .header__logo { font-size: 32px; }
}

